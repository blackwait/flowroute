{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FlowRoute",
  "version": "0.1.0",
  "identifier": "com.black.flowroute",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FlowRoute",
        "width": 420,
        "height": 720,
        "minWidth": 420,
        "maxWidth": 420,
        "minHeight": 600,
        "maxHeight": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/mihomo"]
  }
}
